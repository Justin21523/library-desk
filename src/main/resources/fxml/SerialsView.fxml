<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.SerialsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Serials" styleClass="app-title"/>

    <HBox spacing="8">
        <ComboBox fx:id="bookCombo" prefWidth="240" promptText="Serial bib"/>
        <TextField fx:id="labelField" promptText="Subscription label"/>
        <ComboBox fx:id="frequencyCombo" promptText="Frequency"/>
        <DatePicker fx:id="startPicker"/>
        <Button text="Subscribe" onAction="#onSubscribe" styleClass="primary-button"/>
    </HBox>

    <TableView fx:id="subscriptionTable" prefHeight="180">
        <columns>
            <TableColumn fx:id="subLabelColumn" text="Label" prefWidth="200"/>
            <TableColumn fx:id="subFrequencyColumn" text="Frequency" prefWidth="100"/>
            <TableColumn fx:id="subStatusColumn" text="Status" prefWidth="90"/>
            <TableColumn fx:id="subNextColumn" text="Next expected" prefWidth="120"/>
        </columns>
    </TableView>

    <Label text="Issues for selected subscription"/>
    <TableView fx:id="issueTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="issueEnumColumn" text="Enumeration" prefWidth="180"/>
            <TableColumn fx:id="issueExpectedColumn" text="Expected" prefWidth="120"/>
            <TableColumn fx:id="issueReceivedColumn" text="Received" prefWidth="120"/>
            <TableColumn fx:id="issueStatusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Expect next issue" onAction="#onExpectNext"/>
        <Button text="Check in selected" onAction="#onCheckIn"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
