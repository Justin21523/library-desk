<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.AuditController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Audit Log" styleClass="app-title"/>

    <HBox spacing="8">
        <TextField fx:id="actorFilter" promptText="Filter by actor"/>
        <TextField fx:id="actionFilter" promptText="Filter by action"/>
        <Button text="Apply" onAction="#onApply"/>
        <Button text="Clear" onAction="#onClear"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>

    <TableView fx:id="auditTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timeColumn" text="When" prefWidth="160"/>
            <TableColumn fx:id="actorColumn" text="Actor" prefWidth="110"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="160"/>
            <TableColumn fx:id="entityColumn" text="Entity" prefWidth="120"/>
            <TableColumn fx:id="detailColumn" text="Detail" prefWidth="240"/>
        </columns>
    </TableView>
</VBox>
