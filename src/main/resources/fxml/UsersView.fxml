<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.UsersController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Users" styleClass="app-title"/>
    <Label text="New staff set their own password on first login." wrapText="true"/>

    <HBox spacing="8">
        <TextField fx:id="usernameField" promptText="Username"/>
        <TextField fx:id="fullNameField" promptText="Full name"/>
        <ComboBox fx:id="roleCombo" promptText="Role"/>
        <PasswordField fx:id="passwordField" promptText="Initial password"/>
        <Button text="Create staff" onAction="#onCreate" styleClass="primary-button"/>
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="usernameColumn" text="Username" prefWidth="140"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
            <TableColumn fx:id="activeColumn" text="Active" prefWidth="80"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Deactivate selected" onAction="#onDeactivate"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
