<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.FinesController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Fines" styleClass="app-title"/>
    <Label text="Unpaid fines. Select one to mark it paid or waive it." wrapText="true"/>

    <TableView fx:id="fineTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="fineColumn" text="Fine" prefWidth="70"/>
            <TableColumn fx:id="patronColumn" text="Patron" prefWidth="80"/>
            <TableColumn fx:id="loanColumn" text="Loan" prefWidth="80"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100"/>
            <TableColumn fx:id="createdColumn" text="Created" prefWidth="160"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Mark paid" onAction="#onPay" styleClass="primary-button"/>
        <Button text="Waive" onAction="#onWaive"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
