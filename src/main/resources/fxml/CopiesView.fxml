<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.CopiesController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Book Copies" styleClass="app-title"/>

    <HBox spacing="8">
        <Label text="Book:"/>
        <ComboBox fx:id="bookCombo" prefWidth="320"/>
        <Button text="Reload books" onAction="#onReloadBooks"/>
    </HBox>

    <HBox spacing="8">
        <TextField fx:id="barcodeField" promptText="Barcode"/>
        <TextField fx:id="shelfField" promptText="Shelf location"/>
        <Button text="Add copy" onAction="#onAddCopy" styleClass="primary-button"/>
    </HBox>

    <TableView fx:id="copyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="barcodeColumn" text="Barcode" prefWidth="160"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
            <TableColumn fx:id="shelfColumn" text="Shelf" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Label text="Set status:"/>
        <ComboBox fx:id="statusCombo" prefWidth="160"/>
        <Button text="Apply to selected" onAction="#onSetStatus"/>
        <Button text="Print spine labels" onAction="#onPrintSpineLabels"/>
    </HBox>
</VBox>
