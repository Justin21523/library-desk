<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" prefWidth="760" prefHeight="560"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.MarcEditorController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="MARC Editor" styleClass="app-title"/>

    <HBox spacing="8">
        <Label text="Leader"/>
        <TextField fx:id="leaderField" prefWidth="300"/>
        <Label text="(subfields: $aValue$bValue)"/>
    </HBox>

    <TableView fx:id="fieldTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="tagColumn" text="Tag" prefWidth="60"/>
            <TableColumn fx:id="indColumn" text="Ind" prefWidth="60"/>
            <TableColumn fx:id="contentColumn" text="Content" prefWidth="580"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Add field" onAction="#onAddField"/>
        <Button text="Remove" onAction="#onRemoveField"/>
        <Button text="Up" onAction="#onMoveUp"/>
        <Button text="Down" onAction="#onMoveDown"/>
        <Button text="Validate" onAction="#onValidate"/>
    </HBox>

    <Label text="Validation" styleClass="section-title"/>
    <TextArea fx:id="issuesArea" editable="false" prefRowCount="4"/>

    <HBox spacing="8">
        <Button text="Save" onAction="#onSave" styleClass="primary-button"/>
        <Button text="Cancel" onAction="#onCancel"/>
    </HBox>
</VBox>
