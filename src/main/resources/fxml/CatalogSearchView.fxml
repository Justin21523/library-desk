<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.CatalogSearchController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Catalog Search" styleClass="app-title"/>

    <HBox spacing="8">
        <TextField fx:id="keywordField" promptText="Title, author, subject or ISBN" prefWidth="320"/>
        <Button text="Search" onAction="#onSearch" styleClass="primary-button"/>
        <Button text="Clear" onAction="#onClear"/>
    </HBox>

    <HBox spacing="8">
        <Label text="Narrow:"/>
        <ComboBox fx:id="authorFacet" promptText="Author"/>
        <ComboBox fx:id="subjectFacet" promptText="Subject"/>
        <ComboBox fx:id="yearFacet" promptText="Year"/>
        <ComboBox fx:id="languageFacet" promptText="Language"/>
        <ComboBox fx:id="materialFacet" promptText="Material"/>
    </HBox>

    <TableView fx:id="resultTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="260"/>
            <TableColumn fx:id="authorsColumn" text="Authors" prefWidth="200"/>
            <TableColumn fx:id="yearColumn" text="Year" prefWidth="70"/>
            <TableColumn fx:id="callColumn" text="Call number" prefWidth="140"/>
        </columns>
    </TableView>

    <Label text="Record detail" styleClass="section-title"/>
    <TextArea fx:id="detailArea" editable="false" prefRowCount="8"/>
</VBox>
