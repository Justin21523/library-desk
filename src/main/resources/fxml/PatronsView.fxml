<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.PatronsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Patrons" styleClass="app-title"/>

    <HBox spacing="8">
        <TextField fx:id="membershipField" promptText="Membership no."/>
        <TextField fx:id="nameField" promptText="Full name"/>
        <TextField fx:id="emailField" promptText="Email"/>
        <TextField fx:id="phoneField" promptText="Phone"/>
        <ComboBox fx:id="typeCombo" promptText="Type"/>
        <Button text="Register" onAction="#onRegister" styleClass="primary-button"/>
    </HBox>

    <TableView fx:id="patronTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="membershipColumn" text="Membership" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Suspend selected" onAction="#onSuspend"/>
        <Button text="Refresh" onAction="#onRefresh"/>
        <Button text="Export CSV" onAction="#onExportCsv"/>
        <Button text="Import CSV" onAction="#onImportCsv"/>
    </HBox>
</VBox>
