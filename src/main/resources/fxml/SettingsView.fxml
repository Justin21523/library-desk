<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.SettingsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Settings" styleClass="app-title"/>
    <Label text="Values override application.properties and take effect immediately." wrapText="true"/>

    <GridPane fx:id="settingsGrid" hgap="16" vgap="10"/>

    <Button text="Save" onAction="#onSave" styleClass="primary-button"/>
    <Label fx:id="statusLabel"/>
</VBox>
