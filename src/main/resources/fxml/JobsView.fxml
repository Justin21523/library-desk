<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.JobsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Background Jobs" styleClass="app-title"/>
    <Label wrapText="true"
           text="Scheduled maintenance tasks (overdue sweep, reservation expiry, notices, serials claiming). Select one and run it on demand."/>

    <TableView fx:id="jobTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Job" prefWidth="180"/>
            <TableColumn fx:id="lastRunColumn" text="Last run" prefWidth="170"/>
            <TableColumn fx:id="okColumn" text="OK" prefWidth="60"/>
            <TableColumn fx:id="detailColumn" text="Detail" prefWidth="240"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button text="Run now" onAction="#onRunNow" styleClass="primary-button"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
