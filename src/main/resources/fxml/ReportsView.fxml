<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.ReportsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Reports" styleClass="app-title"/>
    <Label text="Overdue loans" styleClass="section-title"/>

    <HBox spacing="8">
        <Button text="Refresh" onAction="#onRefresh"/>
        <Button text="Run overdue sweep now" onAction="#onRunSweep"/>
        <Button text="Export overdue CSV" onAction="#onExportCsv"/>
    </HBox>

    <TableView fx:id="overdueTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="loanColumn" text="Loan" prefWidth="80"/>
            <TableColumn fx:id="copyColumn" text="Copy" prefWidth="80"/>
            <TableColumn fx:id="patronColumn" text="Patron" prefWidth="80"/>
            <TableColumn fx:id="dueColumn" text="Due" prefWidth="160"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
