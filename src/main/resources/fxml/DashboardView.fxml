<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.DashboardController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Dashboard" styleClass="app-title"/>

    <GridPane hgap="24" vgap="10">
        <Label text="Books:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="booksLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Copies (total / available):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="copiesLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Patrons:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="patronsLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Active loans:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="activeLoansLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Overdue loans:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="overdueLabel" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Pending reservations:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <Label fx:id="reservationsLabel" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <Button text="Refresh" onAction="#onRefresh"/>
</VBox>
