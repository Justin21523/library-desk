<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.WorksController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Works (FRBR)" styleClass="app-title"/>
    <Label wrapText="true"
           text="Group bibliographic records into works by title + author. Select a work to see its manifestations (editions)."/>

    <HBox spacing="8">
        <Button text="Group into works" onAction="#onGroup" styleClass="primary-button"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>

    <HBox spacing="12" VBox.vgrow="ALWAYS">
        <TableView fx:id="workTable" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="workTitleColumn" text="Work" prefWidth="220"/>
                <TableColumn fx:id="workAuthorColumn" text="Author" prefWidth="160"/>
            </columns>
        </TableView>
        <TableView fx:id="manifestationTable" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="bookTitleColumn" text="Manifestation" prefWidth="220"/>
                <TableColumn fx:id="bookIsbnColumn" text="ISBN" prefWidth="120"/>
                <TableColumn fx:id="bookYearColumn" text="Year" prefWidth="70"/>
            </columns>
        </TableView>
    </HBox>
</VBox>
