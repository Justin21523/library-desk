<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.justin.libradesk.controller.CalendarController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Library Calendar" styleClass="app-title"/>
    <Label wrapText="true"
           text="Closed days. Due dates roll forward off these days, and overdue fines do not accrue on them."/>

    <TableView fx:id="dayTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="160"/>
            <TableColumn fx:id="noteColumn" text="Note" prefWidth="320"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <DatePicker fx:id="datePicker"/>
        <TextField fx:id="noteField" promptText="Note (e.g. Public holiday)" prefWidth="260"/>
        <Button text="Add closed day" onAction="#onAdd" styleClass="primary-button"/>
        <Button text="Remove selected" onAction="#onRemove"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
